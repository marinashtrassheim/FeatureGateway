# Скопируйте в .env. Два инстанса Redis из docker compose: фичи (6379) и кэш ответа (6382).
#
# Если у вас остались старые переменные — удалите их: STORAGE_VERSION,
# KEYDB_V1_URL, KEYDB_V2_URL, KEYDB_V3_URL и любые дубликаты URL под разными именами.

KEYDB_DS_URL=redis://127.0.0.1:6379/0
KEYDB_DS_SECOND_URL=redis://127.0.0.1:6379/0

FEATURE_RESPONSE_CACHE_URL=redis://127.0.0.1:6382/0
