# Три Redis из docker-compose.yml — порты хоста 7379 / 7380 / 7381.
# Скопируйте в .env. При смене STORAGE_VERSION выставьте KEYDB_DS_SECOND_URL
# на тот же URL, что и основной KeyDB для этой версии.

STORAGE_VERSION=v1

KEYDB_V1_URL=redis://127.0.0.1:7379/0
KEYDB_V2_URL=redis://127.0.0.1:7380/0
KEYDB_V3_URL=redis://127.0.0.1:7381/0

KEYDB_DS_URL=redis://127.0.0.1:7379/0

# v1 → 7379, v2 → 7380, v3 → 7381
KEYDB_DS_SECOND_URL=redis://127.0.0.1:7379/0

FEATURE_RESPONSE_CACHE_URL=
